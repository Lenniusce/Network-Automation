{# For VLAN interfaces #}

{% for intf in interfaces if "vlan" in intf.name | lower %}
interface {{ intf.name }}
description {{ intf.description }}
no shutdown
mtu 9216
{% if "vrf_isp" in intf.tags %}
vrf member ISP
{% endif %}
{% if "vrf_vxlans" in intf.tags %}
vrf member VXLANS
{% endif %}
{% if "555" in intf.name | lower in intf.name | lower %}
ip forward
ipv6 address use-link-local-only
{% endif %}
no ip redirects
{% for ip in intf.ip_addresses %}
ip address {{ ip.address }}
{% endfor %}
no ipv6 redirects
{% if "444" in intf.name | lower in intf.name | lower %}
ip ospf network point-to-point
ip router ospf UNDERLAY-NET area 0.0.0.0
{% endif %}
ip pim sparse-mode
{% if "fabric_forwarding" in intf.tags %}
fabric forwarding mode anycast-gateway
{% endif %}
{% endfor %}

{# For NVE interface #}
{% if "tor" in device_roles %}
interface nve1
  no shutdown
  description VTEP NVE
  host-reachability protocol bgp
  source-interface loopback1
  member vni 10060
    suppress-arp
    mcast-group 239.1.1.100
  member vni 10100
    mcast-group 239.1.1.100
  member vni 10555 associate-vrf
    mcast-group 239.10.1.1
{% endif %}
{# For port-channel interfaces #}

{% for intf in interfaces if "port-channel" in intf.name | lower %}
interface {{ intf.name }}
{% if "vpc3" in intf.tags %}
switchport access vlan 60
speed 1000
vpc 3
{% endif %}
{% if intf.description %}
description {{ intf.description }}
{% endif %}
{% if "trunk" in intf.tags %}
switchport mode trunk
switchport trunk allowed vlan 60-61,100,444,555
{% endif %}
{% if "vpc_peerlink" in intf.tags %}
spanning-tree port type network
vpc peer-link
{% endif %}
no shutdown

{% endfor %}

{# For Ethernet interfaces #} 

{% for intf in interfaces if "Ethernet" in intf.name %}
interface {{ intf.name }}
{% if intf.description %}
description {{ intf.description }}
{% endif %}
{% if "no_switchport" in intf.tags %}
no switchport
{% endif %}
{% if "trunk" in intf.tags %}
switchport mode trunk
switchport trunk allowed vlan 60-61,100,444,555
{% endif %}
{% if "vrf_isp" in intf.tags %}
vrf member ISP
{% endif %}
{% if "vrf_vxlans" in intf.tags %}
vrf member VXLANS
{% endif %}
{% if intf.mtu is defined and intf.mtu %}
mtu {{ intf.mtu }}
{% endif %}
{% if "ip_ospf_unnumbered" in intf.tags %}
{% include "./nxos/ip_unnumbered.j2" %} {{ '\n' }}
ip pim sparse-mode
{% endif %}
{% if intf.enabled %}
no shutdown
{% endif %}
{% if "channel-group999" in intf.tags %}
channel-group 999 mode active
{% endif %}
{% endfor %}

{# For Mgmt #} 

{% for intf in interfaces if "mgmt" in intf.name | lower %}
interface {{ intf.name }}
vrf member management
ip address {{ intf.ip_addresses[0].address }}
{% endfor %}

{# For Loopbacks #} 

{% for intf in interfaces if "loopback" in intf.name | lower %}
interface {{ intf.name }}
description {{ intf.description }}
{% if "loopback69" in intf.name | lower %}
vrf member VXLANS
{% endif %}
ip address {{ intf.ip_addresses[0].address }}
{% if "loopback0" in intf.name | lower or "loopback1" in intf.name | lower %}
ip router ospf UNDERLAY-NET area 0.0.0.0
{% endif %}
ip pim sparse-mode
{% endfor %}